{
  "servers": {
    "mcp-bridge": {
      "command": "${HOME}/Development/neovim-plugins/mcp-companion/bridge/.venv/bin/python",
      "args": [
        "-m", "mcp_bridge",
        "--config", "${HOME}/.cache/secrets/${USER}.mcpservers.json",
        "--port", "9741"
      ],
      "gracePeriod": "30m",
      "logFile": "${HOME}/Library/Logs/mcp-bridge.log"
    }
  }
}
